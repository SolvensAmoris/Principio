/* Ajuste de la imagen dentro del botón premium */
.btn-logo-img {
    width: 50px;           /* Tamaño ideal para no romper el botón */
    height: 50px;
    margin-right: 20px;    /* Espacio entre logo y texto */
    border-radius: 50%;    /* Estética circular mística */
    border: 1px solid var(--gold-main);
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
    transition: transform 0.3s ease;
}

/* Efecto al pasar el mouse por encima */
.premium-button:hover .btn-logo-img {
    transform: scale(1.1);
    box-shadow: 0 0 15px var(--gold-main);
}
